    int n,i,j,s,u,min,c[10][10],d[10],cnt=1; 
    printf("Dijkstra Algorithm\n"); 
    printf("Enter no of nodes:\n"); 
    scanf("%d",&n); 
    printf("Enter cost matrix:\n"); 
    for(i=0;i<n;i++) 
    for(j=0;j<n;j++) 
        scanf("%d",&c[i][j]); 
        printf("Enter source node:\n"); 
        scanf("%d",&s); 
for(i=0;i<n;i++) d[i]=99; 
    d[s]=0; 
while(cnt<n){ 
        min=99; 
        for(i=0;i<n;i++) 
            if(!v[i] && d[i]<min) 
                min=d[i],u=i; 
                  v[u]=1; 
                  cnt++; 
              for(i=0;i<n;i++) 
            if(!v[i] && d[u]+c[u][i]<d[i]) 
                d[i]=d[u]+c[u][i]; } 
 printf("Shortest Distances:\n"); 
