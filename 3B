#include<stdio.h> 
void main(){ 
    int d[10][10],i,j,k,n; 
   printf("Warshall's Algorithm\n"); 
    printf("Enter no of vertices:\n"); 
    scanf("%d",&n); 
 printf("Enter adjacency matrix:\n"); 
    for(i=0;i<n;i++) 
    for(j=0;j<n;j++) 
        scanf("%d",&d[i][j]); 
for(k=0;k<n;k++) 
    for(i=0;i<n;i++) 
    for(j=0;j<n;j++) 
        if(d[i][k]&&d[k][j]) 
            d[i][j]=1; 
printf("Transitive Closure Matrix:\n"); 
    for(i=0;i<n;i++,printf("\n")) 
        for(j=0;j<n;j++) 
            printf("%d\t",d[i][j]); 
} 
 
