#include<stdio.h>

void main()
{
    int n,m,i,j,p[10],w[10],v[20][20]={0};

    printf("Dynamic Knapsack\n");
    printf("Enter n and capacity:\n");
    scanf("%d%d",&n,&m);

    printf("Enter profit and weight:\n");
    for(i=1;i<=n;i++)
        scanf("%d%d",&p[i],&w[i]);

    for(i=1;i<=n;i++)
    {
        for(j=1;j<=m;j++)
        {
            if(w[i]>j)
                v[i][j]=v[i-1][j];
            else
                v[i][j]=(v[i-1][j]>p[i]+v[i-1][j-w[i]])
                ?v[i-1][j]
                :p[i]+v[i-1][j-w[i]];
        }
    }

    printf("Maximum Profit=%d",v[n][m]);
}
