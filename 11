#include<stdio.h> // 11. Merge sort 
void merge(int a[],int l,int m,int h){ 
    int i=l,j=m+1,k=l,c[20]; 
    while(i<=m&&j<=h) 
        c[k++]=a[i]<a[j]?a[i++]:a[j++]; 
    while(i<=m) c[k++]=a[i++]; 
    while(j<=h) c[k++]=a[j++]; 
    for(i=l;i<=h;i++) 
        a[i]=c[i];} 
void ms(int a[],int l,int h){ 
    int m; 
    if(l<h) { 
        m=(l+h)/2; 
        ms(a,l,m); 
        ms(a,m+1,h); 
        merge(a,l,m,h);  }} 
void main(){ 
    int a[20],n,i; 
    printf("Merge Sort\n"); 
    printf("Enter n:\n"); 
    scanf("%d",&n); 
    printf("Enter elements:\n"); 
    for(i=0;i<n;i++) 
        scanf("%d",&a[i]); 
    ms(a,0,n-1); 
    printf("Sorted Elements:\n"); 
    for(i=0;i<n;i++) 
        printf("%d ",a[i]); }
