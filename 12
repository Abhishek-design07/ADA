#include<stdio.h> 
#include<stdlib.h> 
int x[20],n; 
int place(int k,int i){ 
    int j; 
    for(j=1;j<k;j++) 
        if(x[j]==i || abs(x[j]-i)==abs(j-k)) 
            return 0; 
    return 1;} 
void nq(int k){ 
    int i,j; 
    for(i=1;i<=n;i++) 
    if(place(k,i))  { 
        x[k]=i; 
        if(k==n){ 
            printf("\nSolution:\n"); 
            for(i=1;i<=n;i++) { 
                for(j=1;j<=n;j++) 
                    printf(x[i]==j?"Q ":"- "); 
                printf("\n"); }  } 
        else 
            nq(k+1);  }} 
void main(){ 
    printf("N Queen Problem\n"); 
    printf("Enter N:\n"); 
    scanf("%d",&n); 
    nq(1);}  
